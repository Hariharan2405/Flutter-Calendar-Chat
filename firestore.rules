rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Private data: notes and expenses per user
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public user profiles (for chat discovery)
    match /user_profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Voice & video calls
    match /calls/{callId} {
      allow read, write: if request.auth != null &&
        (request.auth.uid == resource.data.callerId ||
         request.auth.uid == resource.data.calleeId);
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.callerId;

      match /callerCandidates/{id} {
        allow read, write: if request.auth != null;
      }
      match /calleeCandidates/{id} {
        allow read, write: if request.auth != null;
      }
    }

    // Chat rooms — participants field is the source of truth
    match /chats/{chatId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      // Messages: any authenticated user who is a participant of the chat
      match /messages/{messageId} {
        allow read, write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
