rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Private data: notes and expenses per user
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public user profiles (for chat discovery)
    match /user_profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Voice & video calls (signaling only — media goes through Agora)
    match /calls/{callId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.callerId;
      allow read, update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.callerId ||
         request.auth.uid == resource.data.calleeId);
    }

    // Chat rooms — participants can write; any auth user can read (admin view)
    match /chats/{chatId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      allow delete: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      // Messages: any auth user can read (admin view); only participants can write
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
